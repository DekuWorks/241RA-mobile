# 241RA Mobile - Environment Variables Template
# Copy this file to .env and add your actual values

# Backend API URL
EXPO_PUBLIC_API_URL=https://241runners-api-v2.azurewebsites.net

# Supabase (optional client-side storage / realtime)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Google Maps (required for map screen)
# 1. Create a key at https://console.cloud.google.com/ → APIs & Services → Credentials
# 2. Enable Maps SDK for iOS and Maps SDK for Android (mobile) on the same key
# 3. Paste below, then rebuild the dev client (react-native-maps is native-linked)
# 4. Use the same key in website config.json GOOGLE_MAPS_API_KEY (with Maps JavaScript API enabled)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Sentry (production error tracking)
EXPO_PUBLIC_SENTRY_DSN=
